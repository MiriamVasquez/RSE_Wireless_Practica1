/************************************************************************************
* Public functions
************************************************************************************/
void main_task(uint32_t param)
{
    static uint8_t initialized = FALSE;
    if( !initialized )
    {
        initialized = TRUE;  
        hardware_init();
        MEM_Init();
        TMR_Init();
        LED_Init();
        SecLib_Init();
        SerialManager_Init();
        Phy_Init();
        RNG_Init();
        MAC_Init();
#if mEnterLowPowerWhenIdle_c
        PWR_Init();
        PWR_DisallowDeviceToSleep();
#endif
#if gNvmTestActive_d
        NvModuleInit();
#endif
        macInstance = BindToMAC( (instanceId_t)0 );
        Mac_RegisterSapHandlers( MCPS_NWK_SapHandler, MLME_NWK_SapHandler, macInstance );
        App_init();
        mAppTaskHandler = OSA_TaskCreate(OSA_TASK(AppThread), NULL);
        if( NULL == mAppTaskHandler ) { panic(0,0,0,0); return; }
    }
    App_Idle_Task( param );
}

void App_init( void )
{
    mAppEvent = OSA_EventCreate(TRUE);
    gState = stateInit;
    mcPendingPackets = 0;
    mWaitPollConfirm = FALSE;    
    mPollInterval = mDefaultValueOfPollIntervalSlow_c;
    
    /* Setteo de dirección extendida */
    Mac_SetExtendedAddress( (uint8_t*)&mExtendedAddress, macInstance );
    
    /* --- INICIALIZACIÓN DE PARÁMETROS FIJOS --- */
    FLib_MemSet(&mCoordInfo, 0, sizeof(panDescriptor_t));
    mCoordInfo.coordPanId = mDefaultPanId_c;
    mCoordInfo.logicalChannel = mDefaultLogicalChannel_c;
    mCoordInfo.coordAddrMode = gAddrModeShortAddress_c;
    mCoordInfo.coordAddress.shortAddr = mDefaultCoordShortAddr_c;
    /* ------------------------------------------ */

    mTimer_c = TMR_AllocateTimer();
    KBD_Init(App_HandleKeys);
    Serial_InitInterface(&interfaceId, APP_SERIAL_INTERFACE_TYPE, APP_SERIAL_INTERFACE_INSTANCE);
    Serial_SetBaudRate(interfaceId, gUARTBaudRate115200_c);
    Serial_SetRxCallBack(interfaceId, UartRxCallBack, NULL);
    MSG_InitQueue(&mMlmeNwkInputQueue); 
    MSG_InitQueue(&mMcpsNwkInputQueue);
    LED_StartSerialFlash(LED1);

    Serial_Print(interfaceId, "\n\rModo Hardcoded: PAN ID 0x", gAllowToBlock_d);
    Serial_PrintHex(interfaceId, (uint8_t*)&mCoordInfo.coordPanId, 2, 0);
    Serial_Print(interfaceId, " activado.\n\r", gAllowToBlock_d);
}

void AppThread(osaTaskParam_t argument)
{ 
    osaEventFlags_t ev;
    void *pMsgIn = NULL;
    uint8_t rc;
    
    while(1)
    {
        OSA_EventWait(mAppEvent, osaEventFlagsAll_c, FALSE, osaWaitForever_c, &ev);
        if( !gUseRtos_c && !ev) break;
        pMsgIn = NULL;

        if( ev & gAppEvtMessageFromMLME_c )
        {
            pMsgIn = MSG_DeQueue(&mMlmeNwkInputQueue);
            if (pMsgIn) {
                rc = App_WaitMsg(pMsgIn, gMlmeBeaconNotifyInd_c);
                if(rc == errorNoError) {
                    MSG_Free(((nwkMessage_t *)pMsgIn)->msgData.beaconNotifyInd.pBufferRoot);
                }
            }
        }
        
        switch(gState)
        {
        case stateInit:
            Serial_Print(interfaceId, "Saltando escaneo... Intentando asociar directamente.\n\r", gAllowToBlock_d);
            /* Salto directo al estado de asociación */
            gState = stateAssociate;
            OSA_EventSet(mAppEvent, gAppEvtDummyEvent_c);
            break;
            
        case stateAssociate:
            Serial_Print(interfaceId, "Enviando Associate Request a PAN 0x", gAllowToBlock_d);
            Serial_PrintHex(interfaceId, (uint8_t*)&mCoordInfo.coordPanId, 2, 0);
            Serial_Print(interfaceId, " en canal 0x", gAllowToBlock_d);
            Serial_PrintHex(interfaceId, &mCoordInfo.logicalChannel, 1, gPrtHexNewLine_c);
            
            rc = App_SendAssociateRequest();
            if(rc == errorNoError) gState = stateAssociateWaitConfirm;
            break; 
            
        case stateAssociateWaitConfirm:
            if (ev & gAppEvtMessageFromMLME_c && pMsgIn)
            {
                rc = App_WaitMsg(pMsgIn, gMlmeAssociateCnf_c);
                if(rc == errorNoError)
                {
                    rc = App_HandleAssociateConfirm(pMsgIn);
                    if (rc == errorNoError)
                    {
                        Serial_Print(interfaceId, "Conectado exitosamente.\n\r", gAllowToBlock_d);
                        TMR_StartLowPowerTimer(mTimer_c, gTmrSingleShotTimer_c ,mPollInterval, AppPollWaitTimeout, NULL );
                        gState = stateListen;
                    }
                    else
                    {
                        Serial_Print(interfaceId, "Error en asociación. Reintentando en 2 seg...\n\r", gAllowToBlock_d);
                        gState = stateInit; // Vuelve a intentar
                        OSA_EventSet(mAppEvent, gAppEvtDummyEvent_c);
                    }
                }
            }
            break; 

        case stateListen:
            if (ev & gAppEvtMessageFromMLME_c && pMsgIn) rc = App_HandleMlmeInput(pMsgIn);
            if (ev & gAppEvtRxFromUart_c) App_TransmitUartData();
            break;
        }

        if (pMsgIn) { MSG_Free(pMsgIn); pMsgIn = NULL; }

        if (ev & gAppEvtMessageFromMCPS_c)
        {      
            pMsgIn = MSG_DeQueue(&mMcpsNwkInputQueue);
            if (pMsgIn) {
                App_HandleMcpsInput(pMsgIn);
                MSG_Free(pMsgIn);
                pMsgIn = NULL;
            }
        }
        
        if( MSG_Pending(&mMcpsNwkInputQueue) ) OSA_EventSet(mAppEvent, gAppEvtMessageFromMCPS_c);
        if( MSG_Pending(&mMlmeNwkInputQueue) ) OSA_EventSet(mAppEvent, gAppEvtMessageFromMLME_c);
        if( !gUseRtos_c ) break;
    }
}
